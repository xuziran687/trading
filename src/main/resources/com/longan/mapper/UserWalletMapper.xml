<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.longan.mapper.UserWalletMapper">


    <update id="updateByUserId">
        UPDATE user_wallet
        <set>
            <if test="userWallet.balance != null">
                balance = #{userWallet.balance},
            </if>
            <if test="userWallet.freeze != null">
                freeze = #{userWallet.freeze},
            </if>
            <if test="userWallet.totalIncome != null">
                total_income = #{userWallet.totalIncome},
            </if>
            <if test="userWallet.totalOutcome != null">
                total_outcome = #{userWallet.totalOutcome}
            </if>
        </set>
        WHERE user_id = #{userWallet.userId}
    </update>
</mapper>